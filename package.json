{
  "name": "rase-launcher",
  "private": true,
  "version": "1.0.2-hotfix",
  "description": "A sleek, minimalist glassmorphism Minecraft Launcher.",
  "author": "Hamza",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev:frontend": "vite",
    "build:frontend": "tsc -b && vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --out-extension:.js=.cjs --outdir=dist-electron",
    "dev:electron": "npm run build:electron && electron dist-electron/main.cjs",
    "dev": "concurrently -n frontend,electron -c cyan,magenta \"npm run dev:frontend\" \"npm run dev:electron\"",
    "pack": "npm run build:frontend && npm run build:electron && electron-builder --dir",
    "dist": "npm run build:frontend && npm run build:electron && electron-builder",
    "dist:win": "npm run build:frontend && npm run build:electron && electron-builder --win",
    "dist:linux": "npm run build:frontend && npm run build:electron && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "canvas-confetti": "^1.9.4",
    "discord-rpc": "^4.0.1",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "minecraft-launcher-core": "^3.18.2",
    "native-sound-mixer": "^3.4.6-win",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "systeminformation": "^5.31.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
